{
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ],
  "compilerOptions": {
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
        "@public/*": ["./public/*"],
        "@assets/*": ["./src/content/*"],
        "@components/*": ["./src/components/*"],
        "@layouts/*": ["./src/layouts/*"],
        "@pages/*": ["./src/pages/*"],
        "@scripts/*": ["./src/scripts/*"],
        "@stores/*": ["./src/stores/*"],
        "@styles/*": ["./src/styles/*"],
        "@type/*": ["./src/types/*"]
    }
  }
}