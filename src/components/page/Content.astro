---
import { marked } from "marked";

interface Props {
  content: string;
}

const { content } = Astro.props;
---

<section set:html={marked.parse(content)} />

<style>
  section {
    padding: 16px 48px;
    width: 100%;
    max-width: 1536px;
    margin: 0 auto;
  }

  section :global(*) {
    font-size: 16px;
    line-height: 1.75;
  }
</style>
