---
export interface Props {
  title: string;
  titleSettings: {
    type: "bars-below-text" | "bars-behind-text";
    size: "normal" | "large";
  };
}

const {
  title,
  titleSettings: { type, size },
} = Astro.props;
---

{
  title && (
    <div class={`title ${type}`}>
      <div class="title--container">
        <h1 class={size}>{title}</h1>
      </div>
      <div class="title--bar">
        <div class="title--bar-one" />
        <div class="title--bar-two" />
      </div>
    </div>
  )
}

<style lang="scss">
  .title {
    position: relative;

    &--container {
      background-color: var(--color-yellow);

      h1 {
        margin: 0 auto;
        padding: 45px 48px;
        max-width: 1024px;
        text-align: center;
        font-family: var(--font-candy) !important;
        font-weight: 400;
        line-height: 1;

        &.normal {
          font-size: 36px;
          -webkit-text-stroke: 2px #ffffff;
        }

        &.large {
          font-size: 96px;
          -webkit-text-stroke: 5px #ffffff;
        }

        @include screen("lg") {
          &.normal {
            font-size: 60px;
            -webkit-text-stroke: 3px #ffffff;
          }

          &.large {
            font-size: 128px;
            -webkit-text-stroke: 8px #ffffff;
          }
        }
      }
    }

    &--bar {
      &-one,
      &-two {
        height: 16px;
      }

      &-one {
        background-color: var(--color-sand);
      }

      &-two {
        background-color: var(--color-yellow);
      }
    }

    &.bars-behind-text {
      padding-bottom: 46px;

      .title--container {
        position: relative;
        padding: 46px 0;

        h1 {
          display: block;
          position: absolute;
          top: 80px;
          width: 100%;
          left: 50%;
          transform: translateX(-50%);
          padding: 0 48px;

          &.normal {
            top: 90px;
          }

          &.large {
            top: 60px;
          }

          @include screen("lg") {
            &.normal {
              top: 77px;
            }

            &.large {
              top: 40px;
            }
          }
        }
      }
    }
  }
</style>
