---
import { Image } from "astro:assets";

export interface Props {
  src?: string;
  alt?: string;
  fit: "cover" | "contain";
  overlay?: {
    color: string;
    opacity?: number;
    mix?:
      | "color"
      | "screen"
      | "lighten"
      | "color-dodge"
      | "color-burn"
      | "soft-light"
      | "difference"
      | "exclusion"
      | "luminosity";
  };
  attribution?: {
    name: string;
    url: string;
  };
}

const { src, alt, fit = "cover", overlay, attribution } = Astro.props;

const overlayColor = (overlay && overlay?.color) || "transparent";
const overlayOpacity =
  overlay && overlay?.opacity !== null ? overlay.opacity : 0.0;
const overlayMix = (overlay && overlay?.mix) || "color";
---

{
  src && (
    <div class="page-hero">
      <div class="page-hero--container">
        <div class="page-hero--image">
          {overlay?.color && <div class="page-hero--overlay" />}
          <Image
            src={src}
            alt={alt || ""}
            width="922"
            height="457"
            loading="eager"
          />
        </div>
        {attribution?.name && attribution.url && (
          <div class="page-hero--attribution">
            <a href={attribution.url} target="_blank">
              <small>Image credit: {attribution.name}</small>
            </a>
          </div>
        )}
      </div>
    </div>
  )
}

<style
  lang="scss"
  define:vars={{ fit, overlayColor, overlayOpacity, overlayMix }}
>
  .page-hero {
    display: block;
    background-color: var(--color-yellow);
    width: 100%;
    position: relative;

    &--container {
      width: 100%;
      height: auto;
      max-width: 985px;
      max-height: 520px;
      padding: 48px 40px;
      overflow: hidden;
      margin: 0 auto;
    }

    &--image {
      position: relative;

      img {
        display: block;
        height: auto;
        width: 100%;
        max-height: 440px;
        object-fit: var(--fit);
        border-radius: 20px;
      }
    }

    &--overlay {
      position: absolute;
      width: 100%;
      height: 100%;
      left: 50%;
      transform: translateX(-50%);
      border-radius: 20px;
      background-color: var(--overlayColor);
      opacity: var(--overlayOpacity);
      mix-blend-mode: var(--overlayMix);
    }

    &--attribution {
      text-align: center;

      a {
        color: var(--color-black);
      }

      @include screen("md") {
        text-align: right;
        margin-right: 24px;
      }
    }
  }
</style>
