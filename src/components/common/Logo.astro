---
import { Image } from "astro:assets";
import logo from "../../../public/logo/logo-black.png";

interface Props {
  width?: number | `${number}`;
  height?: number | `${number}`;
  loading?: "lazy" | "eager";
}

const { width, height, loading } = Astro.props;
---

<Image
  src={logo}
  alt=""
  width={width || 300}
  height={height || 54}
  loading={loading || "lazy"}
/>
