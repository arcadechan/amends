---
import { Image } from "astro:assets";
import Blacklogo from "../../../public/logo/logo-black.png";
import Yellowlogo from "../../../public/logo/logo-yellow.png";

interface Props {
  width?: number | `${number}`;
  height?: number | `${number}`;
  loading?: "lazy" | "eager";
  alt?: string;
}

const { width, height, loading, alt } = Astro.props;
---

<Image
  id="amends-logo"
  src={Blacklogo}
  alt={alt || ""}
  width={width || 300}
  height={height || 54}
  loading={loading || "lazy"}
  data-dark={Yellowlogo.src}
  data-light={Blacklogo.src}
/>
