---
import { Image } from "astro:assets";
import Logo from "./Logo.astro";
import { getEntry } from "astro:content";
import type { ImageInputFormat } from "astro";
import LastFm from "../LastFm.svelte";
import ThemePicker from "./ThemePicker.svelte";

const SOCIAL_LABELS: Record<string, string> = {
  soundcloud: "SoundCloud",
  github: "GitHub",
  spotify: "Spotify",
};

type Socials = Partial<Record<string, string>>;

interface Settings {
  data: {
    footer_navigation: Array<{
      label: string;
      path: string;
      active: boolean;
    }>;
    motto?: string;
    socials: Socials;
    badges: Array<{
      label: string;
      path?: string;
      active: boolean;
      image: {
        src: string;
        width: number;
        height: number;
        format: ImageInputFormat;
      };
    }>;
  };
}

const settings: Settings = await getEntry("settings", "index");
const lastFmKey = import.meta.env.PUBLIC_LASTFM_KEY;
---

<footer>
  <a href="/" class="logo-link">
    <Logo width="166" height="30" loading="lazy" alt="Amends homepage" />
  </a>
  {
    settings.data.motto && (
      <p>
        <i>{settings.data.motto}</i>
      </p>
    )
  }
  {
    settings.data.footer_navigation.length > 0 && (
      <ul class="links">
        {settings.data.footer_navigation.map((link) => (
          <li>
            <a href={link.path}>{link.label}</a>
          </li>
        ))}
      </ul>
    )
  }
  <ThemePicker client:load />
  {
    Object.entries(settings.data.socials ?? {}).length > 0 && (
      <ul class="platforms">
        {Object.entries(settings.data.socials).map(([platform, url]) => (
          <li>
            <a
              href={url}
              title={SOCIAL_LABELS[platform] ?? platform}
              target="_blank"
            >
              <Image
                src={`/icons/${platform}.png`}
                alt=""
                aria-hidden="true"
                loading="lazy"
                width="20"
                height="20"
              />
              <span class="sr-only">{SOCIAL_LABELS[platform] ?? platform}</span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
  {
    settings.data.badges.length > 0 && (
      <ul class="badges">
        {settings.data.badges.map((badge) => (
          <li>
            {badge?.path ? (
              <a href={badge.path} title={badge.label} target="_blank">
                <Image
                  src={badge.image}
                  alt={badge.label}
                  width={badge.image.width}
                  height={badge.image.height}
                />
              </a>
            ) : (
              <Image
                src={badge.image}
                alt={badge.label}
                width={badge.image.width}
                height={badge.image.height}
                title={badge.label}
              />
            )}
          </li>
        ))}
      </ul>
    )
  }
</footer>
<LastFm client:load apiKey={lastFmKey} />

<style lang="scss">
  footer {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    border-top: 3px solid black;
    margin: 32px 48px;
    padding: 47px 0;
    color: var(--color-text);

    .logo-link {
      line-height: 1;
    }

    p {
      font-size: 12px !important;
    }

    ul.links {
      display: flex;
      list-style-type: none;
      gap: 20px;
      font-size: 14px;
      padding-left: 0;

      a {
        color: var(--color-blue);
        text-decoration: none;

        &:hover {
          text-decoration: underline;
        }
      }
    }

    ul.platforms {
      list-style: none;
      display: flex;
      background-color: var(--color-white);
      border-radius: var(--element-radius);
      padding: 6px;
      gap: 16px;
      box-shadow: var(--box-shadow);

      li {
        a {
          display: block;
          width: 20px;
          height: 20px;

          img {
            height: 100%;
            width: auto;
          }

          &:hover {
            transform: scale(1.2);
          }
        }
      }
    }

    ul.badges {
      display: flex;
      flex-wrap: wrap;
      list-style-type: none;
      padding: 0;
      margin: 0;

      a,
      img {
        display: block;
      }

      a {
        border-radius: 0px;
      }
    }

    @include screen("md") {
      max-width: 954px;
      padding: 47px 48px;
    }

    @include screen("lg") {
      margin: 32px auto;
    }
  }
</style>
