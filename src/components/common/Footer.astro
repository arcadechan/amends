---
import { Image } from "astro:assets";
import Logo from "./Logo.astro";
import { getEntry } from "astro:content";

const SOCIAL_LABELS: Record<string, string> = {
  soundcloud: "SoundCloud",
  github: "GitHub",
  spotify: "Spotify",
};

type Socials = Partial<Record<string, string>>;

interface Settings {
  data: {
    motto?: string;
    socials: Socials;
  };
}

const settings: Settings = await getEntry("settings", "index");
let socials: Socials = null;

if (Object.entries(settings.data.socials).length > 0) {
  socials = settings.data.socials;
}
---

<footer>
  <a href="/" class="logo-link">
    <Logo width="166" height="30" loading="lazy" />
  </a>
  {
    settings.data.motto && (
      <p>
        <i>{settings.data.motto}</i>
      </p>
    )
  }
  <ul>
    {
      socials &&
        Object.entries(socials).map(([platform, url]) => (
          <li>
            <a
              href={url}
              title={SOCIAL_LABELS[platform] ?? platform}
              target="_blank"
            >
              <Image
                src={`/icons/${platform}.png`}
                alt=""
                aria-hidden="true"
                loading="lazy"
                width="20"
                height="20"
              />
              <span class="sr-only">{SOCIAL_LABELS[platform] ?? platform}</span>
            </a>
          </li>
        ))
    }
  </ul>
</footer>

<style lang="scss">
  footer {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    border-top: 3px solid black;
    margin: 32px 32px 0;
    padding: 47px 0;

    .logo-link {
      line-height: 1;
    }

    p {
      font-size: 12px !important;
    }

    ul {
      list-style: none;
      display: flex;
      background-color: #ffffff;
      border-radius: 20px;
      padding: 6px;
      gap: 16px;

      li {
        a {
          display: block;
          width: 20px;
          height: 20px;

          img {
            height: 100%;
            width: auto;
          }
        }
      }
    }
  }
</style>
