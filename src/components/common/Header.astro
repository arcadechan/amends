---
import Logo from "./Logo.astro";
import Navigation from "./Navigation.svelte";
---
<Navigation client:load>
    <div class="logo-container">
        <Logo width="166" height="30"/>
    </div>
</Navigation>

<style lang="scss">
    .logo-container {
        display: flex;
        justify-content: center;
        align-items: center;
        width: calc(100% - 167px);
        position: absolute;
        left: 0;
        margin: 0 83.5px;

        @include screen('md') {
            width: auto;
            margin: 0;
            position: relative;
        }
    }
</style>