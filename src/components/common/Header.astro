---
import { getEntry } from "astro:content";
import Logo from "./Logo.astro";
import Navigation from "./Navigation.svelte";
import LastFm from "../LastFm.svelte";

const settings = await getEntry("settings", "index");
const lastFmKey = import.meta.env.PUBLIC_LASTFM_KEY;
---

<LastFm client:load apiKey={lastFmKey} />
<Navigation client:load links={settings.data.navigation}>
  <div class="logo-container">
    <a href="/">
      <Logo width="166" height="30" loading="eager" />
    </a>
  </div>
</Navigation>

<style lang="scss">
  .logo-container {
    display: flex;
    justify-content: center;
    align-items: center;
    width: calc(100% - 167px);
    position: absolute;
    left: 0;
    margin: 0 83.5px;

    @include screen("md") {
      width: auto;
      margin: 0;
      position: relative;
    }

    a {
      line-height: 1;
    }
  }
</style>
