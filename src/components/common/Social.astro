---
const { platform, username } = Astro.props
---
<a href={`https://www.${platform}.com/${username}`}>{platform}</a>

<style type="scss">
  a {
    padding: 0.5rem 1rem;
    color: white;
    background-color: #4c1d95;
    text-decoration: none;

    &:hover {
        background-color: white;
        color: black;
        outline: 1px solid black;
    }
  }
</style>