---
import type { ImageInputFormat } from "astro";

interface Props {
  opengraph: {
    type?: "article";
    image?: {
      src: string;
      width: number;
      height: number;
      format: ImageInputFormat;
    };
    publishedTime?: Date;
    article?: string;
    tags?: string[];
  };
}

const { opengraph } = Astro.props;
---

{
  opengraph?.publishedTime && (
    <meta
      property="og:published_time"
      content={opengraph.publishedTime.toISOString()}
    />
  )
}
{
  opengraph?.article && (
    <meta property="og:article" content={opengraph.article} />
  )
}

{
  opengraph?.tags &&
    opengraph.tags.map((tag) => <meta property="og:tag" content={tag} />)
}
