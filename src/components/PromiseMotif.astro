---
import { Image } from "astro:assets";
import BlackPromise from "@public/assets/promise-black.png";
import YellowPromise from "@public/assets/promise-yellow.png";
---

<Image
  src={BlackPromise}
  alt=""
  aria-hidden="true"
  width="144"
  height="44"
  loading="lazy"
  data-dark={YellowPromise.src}
  data-light={BlackPromise.src}
/>

<style>
  img {
    display: block;
    width: 144px;
    margin: 32px auto 0;
  }
</style>
