---
import type { ImageInputFormat } from "astro";
import { Image } from "astro:assets";

interface Props {
  id: string;
  data: {
    title: string;
    subtitle?: string | null;
    hero: {
      image: {
        src: string;
        width: number;
        height: number;
        format: ImageInputFormat;
      };
      alt?: string;
      overlay?: {
        color: string;
        opacity?: number;
        mix?:
          | "none"
          | "color"
          | "screen"
          | "lighten"
          | "color-dodge"
          | "color-burn"
          | "soft-light"
          | "difference"
          | "exclusion"
          | "luminosity";
      };
      attribution?: {
        name: string;
        url: string;
      };
    };
  };
}

const {
  id,
  data: { title, subtitle, hero },
} = Astro.props;
---

<a href={`/blog/${id}`}>
  <article>
    <Image src={hero?.image} alt={hero.alt || ""} />
    {hero?.overlay?.color && <div class="post-card--overlay" />}
    <div class="post-card--title">
      <h2>{title}</h2>
      {subtitle && <h3>{subtitle}</h3>}
    </div>
  </article>
</a>

<style
  lang="scss"
  define:vars={{
    overlayColor: hero?.overlay?.color || "transparent",
    overlayOpacity:
      hero?.overlay && hero?.overlay?.opacity !== null
        ? hero.overlay.opacity
        : 0.5,
    overlayMix: hero?.overlay?.mix || "none",
  }}
>
  $black: var(--color-black);

  a {
    display: block;
    width: 100%;
    height: 100%;
    outline-offset: 5px;
    border-radius: 20px;
    text-decoration: none;
    overflow: hidden;

    &:focus {
      outline: 4px solid var(--color-black);
    }

    &:hover {
      text-decoration: underline #ffffff 2px;
      text-underline-offset: 3px;
      transform: scale(101%);
    }

    article {
      display: flex;
      align-items: flex-end;
      position: relative;
      height: 460px;
      max-width: 954px;

      img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        z-index: 0;
      }

      .post-card--overlay {
        position: absolute;
        width: 100%;
        height: 100%;
        background-color: var(--overlayColor);
        opacity: var(--overlayOpacity);
        mix-blend-mode: var(--overlayMix);
      }

      .post-card--title {
        position: relative;
        z-index: 1;
        padding: 24px;
        width: 100%;
        border-bottom-left-radius: 20px;
        border-bottom-right-radius: 20px;
        background-image: linear-gradient(
          to right,
          color-mix(in srgb, var(--color-black) 75%, transparent) 20%,
          color-mix(in srgb, var(--color-black) 30%, transparent)
        );
        color: #ffffff;
        transition: all 2000s ease-in-out;

        h2,
        h3 {
          margin: 0;
        }

        h2 {
          font-size: 24px;
          font-weight: bold;
        }

        h3 {
          font-size: 18px;
          font-weight: bold;
          font-style: italic;
        }
      }
    }
  }
</style>
