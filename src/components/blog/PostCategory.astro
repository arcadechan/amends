---
import type { CollectionEntry } from "astro:content";

interface Props extends CollectionEntry<"categories"> {}

const {
  data: { name },
} = Astro.props;
---

<div class="content-container">
  <p aria-label="Category">
    &bull; {name} &bull;
  </p>
</div>

<style>
  p {
    text-align: center;
  }
</style>
