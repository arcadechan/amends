---
import { getCollection, render } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/page/Hero.astro";
import Title from "@components/page/Title.astro";
import Body from "@components/page/Body.astro";
import PromiseMotif from "@components/PromiseMotif.astro";

export async function getStaticPaths() {
  const allPages = await getCollection("pages", ({ data }) => {
    return data.draft !== true;
  });

  return allPages.map((page) => ({
    params: { page: page.id },
    props: { page },
  }));
}

const { page } = Astro.props;
const { Content } = await render(page);

const { hero, title, titleSettings, excerpt } = page.data;
---

<BaseLayout
  pageTitle={title}
  pageExcerpt={excerpt}
  opengraph={{
    type: "website",
    image: hero.image,
  }}
>
  <Hero {...hero} />
  <Title {...{ title, titleSettings }} />
  <Body>
    <Content />
  </Body>
  <PromiseMotif />
</BaseLayout>
