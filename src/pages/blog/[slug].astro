---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Hero from "../../components/page/Hero.astro";
import Title from "../../components/page/Title.astro";
import Body from "../../components/page/Body.astro";
import PromiseMotif from "../../components/PromiseMotif.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");

  return allPosts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post }: { post: any } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout pageTitle={post.data.title?.title}>
  <Hero {...post.data.hero} />
  <Title {...post.data.title} />
  <Body>
    <Content />
  </Body>
  <PromiseMotif />
</BaseLayout>
